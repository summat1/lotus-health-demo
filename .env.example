# Strava API (public-facing client ID only — secret stays server-side)
VITE_STRAVA_CLIENT_ID=your_strava_client_id_here

# Strava secret — only used in the Vercel serverless function, never in the browser
STRAVA_CLIENT_SECRET=your_strava_client_secret_here

# Anthropic API key — server-side only (no VITE_ prefix = never sent to browser)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
